{
  "manifestVersion": 5,
  "id": "com.openlayer.photoshop",
  "name": "OpenLayer",
  "version": "0.4.0",
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "25.0.0"
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "network": {
      "domains": "all"
    }
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "openlayer.panel",
      "label": {
        "default": "OpenLayer"
      },
      "minimumSize": {
        "width": 320,
        "height": 480
      },
      "maximumSize": {
        "width": 720,
        "height": 1200
      },
      "preferredDockedSize": {
        "width": 380,
        "height": 720
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 760
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon_D.png",
          "scale": [1, 2],
          "theme": ["darkest", "dark", "medium"]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon_N.png",
          "scale": [1, 2],
          "theme": ["lightest", "light"]
        }
      ]
    }
  ],
  "icons": [
    {
      "width": 23,
      "height": 23,
      "path": "icons/icon_D.png",
      "scale": [1, 2],
      "theme": ["dark", "darkest"],
      "species": ["generic"]
    },
    {
      "width": 23,
      "height": 23,
      "path": "icons/icon_N.png",
      "scale": [1, 2],
      "theme": ["lightest", "light"],
      "species": ["generic"]
    }
  ]
}
